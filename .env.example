# Firebase Web App configuration (client-side, safe to expose).
# Copy this file to .env.local and fill in the values from your Firebase project settings.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=

# --- Seeding only (Firebase Admin SDK) ---
# Required ONLY to run `npm run seed`. Download a service account key from
# Firebase Console > Project Settings > Service Accounts > Generate new private key,
# then paste the absolute path to that JSON file here. Never commit this file.
FIREBASE_SERVICE_ACCOUNT_PATH=

# ===========================================================================
# WhatsApp AI Sales Bot (SERVER-ONLY — never exposed to the browser)
# ===========================================================================
# These power the WhatsApp webhook (src/app/api/whatsapp/*). In production set
# them as encrypted/runtime variables in the Cloudflare Pages dashboard
# (Settings > Variables and Secrets), NOT as NEXT_PUBLIC_*.

# WhatsApp Cloud API (Meta > WhatsApp > API Setup)
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
# A random string you choose; you enter the SAME value in Meta's webhook config.
WHATSAPP_VERIFY_TOKEN=
# App secret (Meta > App Settings > Basic) — used to verify X-Hub-Signature-256.
WHATSAPP_APP_SECRET=

# OpenAI (https://platform.openai.com/api-keys)
OPENAI_API_KEY=

# Firebase service account — lets the edge webhook read/write Firestore without a
# user session (the front-end keeps using the Web SDK). Use the SAME service
# account JSON as seeding. Provide EITHER the three fields below ...
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# Paste the private_key value verbatim (keep the \n escapes, wrap in quotes).
FIREBASE_PRIVATE_KEY=
# ... OR provide the whole JSON blob in one variable instead of the three above:
# FIREBASE_SERVICE_ACCOUNT_JSON={"project_id":"...","client_email":"...","private_key":"..."}

# Optional: public origin used to build product-image links sent to WhatsApp.
# Falls back to the incoming request origin if unset (set it if you front the
# app with a custom domain/CDN).
PUBLIC_BASE_URL=
